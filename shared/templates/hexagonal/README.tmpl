## Configuration

Edit `config/config.yaml`:

```yaml
app:
  name: {{.AppName}}
  port: 7000
  debug:
    config: false
  fiber:
    enable_print_routes: true
    enable_splitting_on_parsers: true{{if eq .CacheType "redis"}}
  cache:
    redis:
      addr: localhost:6379
      username:
      password:
      db: 0{{end}}{{if eq .DatabaseType "postgresql"}}
  datastore:
    psql:
      host: localhost
      port: 5432
      username: myapp
      password: myapp
      db: myapp{{else if eq .DatabaseType "mysql"}}
  datastore:
    mysql:
      host: localhost
      port: 3306
      username: myapp
      password: myapp
      db: myapp{{else if eq .DatabaseType "mongodb"}}
  datastore:
    mongo:
      uri: mongodb://localhost:27017
      database: myapp{{else if eq .DatabaseType "sqlite"}}
  datastore:
    sqlite:
      path: ./data/myapp.db{{end}}
```

